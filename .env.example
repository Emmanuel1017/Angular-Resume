# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# After editing .env, run:  node scripts/set-env.js
# (or just `npm start` / `npm run build` — it runs automatically via prestart/prebuild)
# ─────────────────────────────────────────────────────────────────────────────


# ── Kori AI — OpenRouter (default provider, supports 200+ models) ─────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here


# ── Kori AI — OpenAI (optional, direct GPT access) ────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── Kori AI — Anthropic Claude (optional, direct Claude access) ───────────────
# Get your key at https://console.anthropic.com/
CLAUDE_API_KEY=


# ── Firebase ──────────────────────────────────────────────────────────────────
# Used by BOTH this Angular portfolio AND the portfolio-admin Flutter app.
# One Firebase project powers everything.
#
# Where to get these values:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → ⚙️ Project Settings → General → Your apps
#   3. Click the web app (</> icon) → copy the firebaseConfig object values below
#
# The Flutter admin app reads these same values via:
#   cd ../portfolio-admin && dart scripts/gen_firebase_options.dart
#   (generates lib/firebase_options.dart automatically from this file)
#
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
