# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# After editing .env, run:  node scripts/set-env.js
# (or just `npm start` / `npm run build` — it runs automatically via prestart/prebuild)
# ─────────────────────────────────────────────────────────────────────────────


# ── Kori AI — OpenRouter (default provider, supports 200+ models) ─────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here


# ── Kori AI — OpenAI (optional, direct GPT access) ────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── Kori AI — Anthropic Claude (optional, direct Claude access) ───────────────
# Get your key at https://console.anthropic.com/
CLAUDE_API_KEY=


# ── Firebase (analytics + optional realtime DB) ───────────────────────────────
# Get these from your Firebase project settings → General → Your apps
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
